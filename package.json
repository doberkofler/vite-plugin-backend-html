{
	"name": "vite-plugin-backend-html",
	"version": "0.1.0",
	"type": "module",
	"license": "MIT",
	"author": "Dieter Oberkofler",
	"files": [
		"dist"
	],
	"keywords": [
		"vite",
		"vite-plugin",
		"frontend",
		"backend",
		"html"
	],
	"scripts": {
		"dev": "tsdown --watch",
		"build": "tsdown",
		"lint": "prettier --check . && oxlint --type-aware --type-check && tsc",
		"test": "vitest run --coverage",
		"ci": "npm run lint && npm run build && npm run test",
		"create-changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
		"pack-local": "rm -f *.tgz && npm run build && npm pack",
		"prepare": "husky"
	},
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./dist/index.mjs",
		"./package.json": "./package.json"
	},
	"engines": {
		"node": ">=22"
	},
	"repository": {
		"type": "git",
		"url": "git://github.com/doberkofler/vite-plugin-merge-css.git"
	},
	"homepage": "https://github.com/doberkofler/vite-plugin-merge-css#readme",
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@types/debug": "^4.1.12",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.0",
		"conventional-changelog": "^7.2.0",
		"conventional-changelog-angular": "^8.3.0",
		"conventional-changelog-cli": "^5.0.0",
		"eslint-plugin-regexp": "3.1.0",
		"husky": "^9.1.7",
		"oxlint": "^1.56.0",
		"oxlint-tsgolint": "^0.17.0",
		"prettier": "^3.8.1",
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3",
		"vite": "^7.0.0 || ^8.0.0",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"debug": "^4.4.3"
	},
	"peerDependencies": {
		"vite": "^7.0.0 || ^8.0.0"
	}
}
